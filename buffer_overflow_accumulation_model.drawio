<mxfile host="app.diagrams.net" modified="2026-07-09T00:00:00.000Z" agent="Claude" version="24.0.0" type="device">
  <diagram id="bufferoverflow" name="Buffer overflow accumulation model">
    <mxGraphModel dx="900" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="860" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="&lt;b&gt;Why the host buffer overflows after N loops — WP3 accumulation model&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;rate = 45,000 S/s · reading 1,000 samples per loop · single channel ai0&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fontColor=#2C2C2A;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="8" width="780" height="40" as="geometry" />
        </mxCell>

        <mxCell id="card" value="&lt;b&gt;Card (producer)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;45,000 S/s → adds 1,813 samples/loop&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=15;fillColor=#E1F5EE;strokeColor=#0F6E56;fontColor=#04342C;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="280" y="56" width="190" height="64" as="geometry" />
        </mxCell>

        <mxCell id="buffer" value="&lt;b&gt;Host buffer&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;100,000 samples (measured)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#EEEDFE;strokeColor=#534AB7;fontColor=#26215C;fontSize=13;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="280" y="160" width="190" height="200" as="geometry" />
        </mxCell>

        <mxCell id="fill" value="&lt;font style=&quot;font-size:10px&quot;&gt;accumulating&lt;br&gt;+813 samples / loop&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FAEEDA;strokeColor=#854F0B;fontColor=#412402;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="290" y="298" width="170" height="54" as="geometry" />
        </mxCell>

        <mxCell id="python" value="&lt;b&gt;Python (consumer)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;task.read() removes 1,000 samples/loop&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=15;fillColor=#F1EFE8;strokeColor=#5F5E5A;fontColor=#2C2C2A;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="280" y="400" width="190" height="64" as="geometry" />
        </mxCell>

        <mxCell id="net" value="&lt;b&gt;Net inflow&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;1,813 added − 1,000 read = +813 / loop&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#FAEEDA;strokeColor=#854F0B;fontColor=#412402;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="520" y="160" width="290" height="54" as="geometry" />
        </mxCell>

        <mxCell id="formula" value="&lt;b&gt;Loops until overflow&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;= buffer ÷ net inflow&lt;br&gt;= 100,000 ÷ 813 ≈ 123 loops&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#F1EFE8;strokeColor=#5F5E5A;fontColor=#2C2C2A;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="520" y="232" width="290" height="66" as="geometry" />
        </mxCell>

        <mxCell id="result" value="&lt;b&gt;Overflow at loop 123&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;error -200279 (app can't keep up)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#FCEBEB;strokeColor=#A32D2D;fontColor=#501313;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="520" y="316" width="290" height="54" as="geometry" />
        </mxCell>

        <mxCell id="expmeas" value="&lt;b&gt;Expected vs measured&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;theoretical ~187 loops · measured 123 (Windows jitter)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#F1EFE8;strokeColor=#5F5E5A;fontColor=#2C2C2A;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="520" y="388" width="290" height="54" as="geometry" />
        </mxCell>

        <mxCell id="jitter" value="&lt;b&gt;Windows is not real-time — this is why the loop number changes run to run&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;At loop 75, Python was delayed 0.6266 s instead of ~0.033 s. During that pause the card kept sampling: 45,000 × 0.6266 ≈ 27,000 samples added in a single loop, while Python removed only 1,000. This single jump made the buffer fill faster, so overflow arrived at loop 123 instead of the theoretical ~187 (193 one day, 130 another).&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FCEBEB;strokeColor=#A32D2D;fontColor=#501313;fontSize=13;align=left;spacingLeft=10;spacingRight=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="770" height="92" as="geometry" />
        </mxCell>

        <mxCell id="ec" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#0F6E56;strokeWidth=1.5;" edge="1" parent="1" source="card" target="buffer"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ep" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#5F5E5A;strokeWidth=1.5;" edge="1" parent="1" source="buffer" target="python"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="lbn" style="endArrow=none;dashed=1;html=1;strokeColor=#854F0B;exitX=1;exitY=0.2;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="buffer" target="net"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="enf" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#5F5E5A;strokeWidth=1.5;" edge="1" parent="1" source="net" target="formula"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="efr" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#A32D2D;strokeWidth=1.5;" edge="1" parent="1" source="formula" target="result"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="lbj" style="endArrow=none;dashed=1;html=1;strokeColor=#A32D2D;exitX=0;exitY=0.75;exitDx=0;exitDy=0;entryX=0.2;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="buffer" target="jitter"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="legend" value="&lt;font color=&quot;#0F6E56&quot;&gt;■&lt;/font&gt; producer / consumer&amp;nbsp;&amp;nbsp; &lt;font color=&quot;#534AB7&quot;&gt;■&lt;/font&gt; buffer&amp;nbsp;&amp;nbsp; &lt;font color=&quot;#854F0B&quot;&gt;■&lt;/font&gt; accumulation (the problem)&amp;nbsp;&amp;nbsp; &lt;font color=&quot;#A32D2D&quot;&gt;■&lt;/font&gt; overflow / cause" style="text;html=1;align=left;verticalAlign=middle;fontColor=#2C2C2A;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="570" width="780" height="24" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
