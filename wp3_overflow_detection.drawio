<mxfile host="app.diagrams.net" modified="2026-07-09T00:00:00.000Z" agent="Claude" version="24.0.0" type="device">
  <diagram id="wp3overflow" name="WP3 overflow detection">
    <mxGraphModel dx="900" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="860" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="&lt;b&gt;WP3 — finding where data loss happens (single channel ai0, PXIe-6386 Slot 3)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;built step by step; each stage tested on the real hardware before adding the next&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fontColor=#2C2C2A;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="8" width="780" height="40" as="geometry" />
        </mxCell>

        <mxCell id="goal" value="&lt;b&gt;Goal&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;does the host buffer overflow on real hardware — and is the cause the card, the bus, or the software?&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=15;fillColor=#F1EFE8;strokeColor=#5F5E5A;fontColor=#2C2C2A;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="250" y="54" width="300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s1" value="&lt;b&gt;Stage 1 — simplest finite read&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;no overflow · found minimum rate 20 kS/s (error -200077)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=15;fillColor=#EAF3DE;strokeColor=#3B6D11;fontColor=#173404;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="250" y="144" width="300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s2" value="&lt;b&gt;Stage 2 — continuous read loop&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;no overflow · Python faster than the card&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=15;fillColor=#EAF3DE;strokeColor=#3B6D11;fontColor=#173404;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="250" y="228" width="300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s3" value="&lt;b&gt;Stage 3 — raise rate, reading only&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;no overflow even at 14 MS/s (28 of 250 MB/s on the bus)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=15;fillColor=#EAF3DE;strokeColor=#3B6D11;fontColor=#173404;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="250" y="312" width="300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s4" value="&lt;b&gt;Stage 4 — add calculations&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;no overflow at 14 MS/s · light processing is fast enough&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=15;fillColor=#EAF3DE;strokeColor=#3B6D11;fontColor=#173404;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="250" y="396" width="300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s5" value="&lt;b&gt;Stage 5 — add live plotting (heavy work)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;OVERFLOW at ~45 kS/s · error -200279 · after ~193 loops&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=15;fillColor=#FCEBEB;strokeColor=#A32D2D;fontColor=#501313;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="250" y="480" width="300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="concl" value="&lt;b&gt;Conclusion&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;the software is the bottleneck — updating the live plot, not the card or the bus, is what stops Python from emptying the host buffer in time&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#EEEDFE;strokeColor=#534AB7;fontColor=#26215C;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="250" y="564" width="300" height="76" as="geometry" />
        </mxCell>

        <mxCell id="disc" value="&lt;b&gt;Hardware confirmed&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;20 kS/s minimum sample rate&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#FAEEDA;strokeColor=#854F0B;fontColor=#412402;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="600" y="149" width="220" height="50" as="geometry" />
        </mxCell>

        <mxCell id="finding" value="&lt;b&gt;Key comparison (1 channel)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;br&gt;• reading only → kept up to 14 MS/s&lt;br&gt;• reading + live plot → overflow at ~45 kS/s&lt;br&gt;&lt;br&gt;≈ 300× slower → the software (plotting), not the card or bus, is the limit&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FAEEDA;strokeColor=#854F0B;fontColor=#412402;fontSize=13;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="480" width="220" height="160" as="geometry" />
        </mxCell>

        <mxCell id="eg" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#5F5E5A;strokeWidth=1.5;" edge="1" parent="1" source="goal" target="s1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#3B6D11;strokeWidth=1.5;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#3B6D11;strokeWidth=1.5;" edge="1" parent="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e34" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#3B6D11;strokeWidth=1.5;" edge="1" parent="1" source="s3" target="s4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e45" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#A32D2D;strokeWidth=1.5;" edge="1" parent="1" source="s4" target="s5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5c" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#534AB7;strokeWidth=1.5;" edge="1" parent="1" source="s5" target="concl"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="ld1" style="endArrow=none;dashed=1;html=1;strokeColor=#854F0B;" edge="1" parent="1" source="s1" target="disc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ld5" style="endArrow=none;dashed=1;html=1;strokeColor=#854F0B;" edge="1" parent="1" source="s5" target="finding"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="legend" value="&lt;font color=&quot;#3B6D11&quot;&gt;■&lt;/font&gt; stage passed (no overflow)&amp;nbsp;&amp;nbsp; &lt;font color=&quot;#A32D2D&quot;&gt;■&lt;/font&gt; overflow point&amp;nbsp;&amp;nbsp; &lt;font color=&quot;#854F0B&quot;&gt;■&lt;/font&gt; key finding&amp;nbsp;&amp;nbsp; &lt;font color=&quot;#534AB7&quot;&gt;■&lt;/font&gt; conclusion" style="text;html=1;align=left;verticalAlign=middle;fontColor=#2C2C2A;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="654" width="780" height="24" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
